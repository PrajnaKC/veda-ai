{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["es2021"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "..",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    
  },
  "include": ["src/**/*.ts", "../src/**/*.ts"],
  "exclude": ["node_modules"]
}
